---
interface Props {
  title: string;
}

const { title } = Astro.props;
const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - primavera-ui</title>
    <script is:inline>
      (function() {
        const theme = localStorage.getItem("theme");
        if (theme === "dark" || (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
  </head>
  <body>
    <nav>
      <a href="/" class:list={["nav-link", { active: pathname === "/" }]}>primavera-ui</a>
      <a href="/" class:list={["nav-link", { active: pathname === "/" }]}>Intro</a>
      <a href="/otp" class:list={["nav-link", { active: pathname.startsWith("/otp") }]}>OTP</a>
      <button id="theme-toggle" aria-label="Toggle theme"></button>
    </nav>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  html[data-theme="dark"] {
    color-scheme: dark;
  }

  body {
    font-family: system-ui, sans-serif;
    margin: 0;
    background: #fafafa;
    color: #111;
  }

  html[data-theme="dark"] body {
    background: #1a1a1a;
    color: #e5e5e5;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 2rem;
    border-bottom: 1px solid #e5e5e5;
    background: white;
  }

  html[data-theme="dark"] nav {
    background: #222;
    border-bottom-color: #333;
  }

  nav .nav-link {
    font-size: 0.875rem;
    color: #666;
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
  }

  nav .nav-link:first-child {
    font-weight: 600;
    color: #111;
    margin-right: 1rem;
    border-bottom: none;
  }

  html[data-theme="dark"] nav .nav-link {
    color: #999;
  }

  html[data-theme="dark"] nav .nav-link:first-child {
    color: #e5e5e5;
  }

  nav .nav-link:hover {
    color: #111;
  }

  html[data-theme="dark"] nav .nav-link:hover {
    color: #e5e5e5;
  }

  nav .nav-link.active {
    color: #3b82f6;
    border-bottom-color: #3b82f6;
  }

  #theme-toggle {
    margin-left: auto;
    background: none;
    border: 1px solid #ccc;
    border-radius: 0.25rem;
    padding: 0.25rem 0.5rem;
    cursor: pointer;
    font-size: 1rem;
    line-height: 1;
  }

  html[data-theme="dark"] #theme-toggle {
    border-color: #555;
  }

  main {
    padding: 2rem;
  }
</style>

<script>
  class Theme {
    active: string;
    private btn: HTMLElement;

    constructor(btn: HTMLElement) {
      this.btn = btn;
      this.active = document.documentElement.getAttribute("data-theme") || "light";
      this.updateIcon();
      this.btn.addEventListener("click", () => this.toggle());
    }

    set(theme: string) {
      this.active = theme;
      document.documentElement.setAttribute("data-theme", theme);
      localStorage.setItem("theme", theme);
      this.updateIcon();
    }

    toggle() {
      this.set(this.active === "light" ? "dark" : "light");
    }

    private updateIcon() {
      this.btn.textContent = this.active === "light" ? "\u263C" : "\u263E";
    }
  }

  new Theme(document.getElementById("theme-toggle")!);
</script>
