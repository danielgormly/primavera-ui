---
import Layout from '../layouts/Layout.astro';
import { Content as Readme } from '../../../readme.md';
---
<Layout title="Introduction">
  <div class="readme">
    <Readme />
  </div>
</Layout>

<style is:global>
  .readme {
    max-width: 40rem;
  }
  .readme p {
    color: #444;
    line-height: 1.6;
  }
  html[data-theme="dark"] .readme p {
    color: #bbb;
  }
  .readme ul {
    padding-left: 1.25rem;
  }
  .readme li {
    margin-bottom: 0.5rem;
    line-height: 1.5;
  }
  .readme a {
    color: #3b82f6;
    text-decoration: none;
    font-weight: 500;
  }
  .readme a:hover {
    text-decoration: underline;
  }
  .readme pre {
    background: #1e1e1e;
    color: #d4d4d4;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    font-size: 0.875rem;
  }
</style>
